#!/usr/bin/env bash
# arxiv-brew CLI wrapper (optional convenience — all commands also work via python -m arxiv_brew)
set -euo pipefail

PYTHON="${PYTHON:-python3}"

usage() {
    cat <<EOF
arxiv-brew — Your daily arXiv paper filter.

Usage:
  arxiv-brew init                    Set up config/my_research.md
  arxiv-brew run [options]           Run full pipeline (default)
  arxiv-brew pull [options]          Pull and filter today's papers
  arxiv-brew download FILE [options] Download full text for filtered papers
  arxiv-brew summarize FILE [options] Generate digest from downloaded papers
  arxiv-brew db COMMAND              Paper archive management (status, cleanup)
  arxiv-brew keywords                Show keyword DB stats
  arxiv-brew version                 Show version

Run 'arxiv-brew <command> --help' for command-specific options.

Examples:
  arxiv-brew init
  arxiv-brew run --research-profile config/my_research.md --init-keywords --digest-only
  arxiv-brew pull -o papers.json
  arxiv-brew db cleanup --retention-days 14
EOF
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    init)
        exec "$PYTHON" -c "from arxiv_brew.init import run_init; raise SystemExit(run_init())"
        ;;
    run|pipeline)
        exec "$PYTHON" -m arxiv_brew "$@"
        ;;
    pull)
        exec "$PYTHON" -m arxiv_brew.pull "$@"
        ;;
    download)
        exec "$PYTHON" -m arxiv_brew.download "$@"
        ;;
    summarize)
        exec "$PYTHON" -m arxiv_brew.summarize "$@"
        ;;
    db)
        exec "$PYTHON" -m arxiv_brew.db "$@"
        ;;
    keywords)
        exec "$PYTHON" -c "
from arxiv_brew.keywords import KeywordDB
db = KeywordDB('config/keywords.json')
if not db.data.get('clusters'):
    print('No keyword DB yet. Run: arxiv-brew init')
else:
    s = db.stats()
    print(f'Keywords: {s[\"total_keywords\"]}')
    print(f'Sources:  {s[\"by_source\"]}')
    print(f'Clusters: {s[\"by_cluster\"]}')
    print(f'Updated:  {s[\"last_updated\"]}')
"
        ;;
    version|--version|-v)
        exec "$PYTHON" -m arxiv_brew --version
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $cmd"
        usage
        exit 1
        ;;
esac
